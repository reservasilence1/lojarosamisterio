{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/frete",
      "destination": "https://rosamisteriofrete.vercel.app"
    },
    {
      "source": "/frete/:path*",
      "destination": "https://rosamisteriofrete.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
